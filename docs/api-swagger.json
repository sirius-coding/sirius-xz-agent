{
  "openapi": "3.0.3",
  "info": {
    "title": "sirius-xz-agent API",
    "version": "0.1.0",
    "description": "Agent RAG and Knowledge Management APIs"
  },
  "servers": [
    {
      "url": "http://localhost:8081",
      "description": "Local runtime"
    }
  ],
  "paths": {
    "/api/agent/summary": {
      "get": {
        "summary": "Get agent profile summary",
        "operationId": "getAgentSummary",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "Sirius"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Agent summary payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentSummary"
                }
              }
            }
          }
        }
      }
    },
    "/api/agent/ask": {
      "get": {
        "summary": "Ask a question to the agent",
        "operationId": "askAgent",
        "parameters": [
          {
            "name": "question",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Answer generated from retrieved knowledge",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentAnswer"
                }
              }
            }
          }
        }
      }
    },
    "/api/knowledge/documents": {
      "get": {
        "summary": "List all knowledge documents",
        "operationId": "listKnowledgeDocuments",
        "responses": {
          "200": {
            "description": "Knowledge document list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/KnowledgeDocument"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create or update a knowledge document",
        "operationId": "upsertKnowledgeDocument",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/KnowledgeDocumentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upserted knowledge document",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KnowledgeDocument"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request payload"
          }
        }
      }
    },
    "/api/knowledge/documents/{id}": {
      "get": {
        "summary": "Get a knowledge document by id",
        "operationId": "getKnowledgeDocumentById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Knowledge document",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KnowledgeDocument"
                }
              }
            }
          },
          "404": {
            "description": "Document not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AgentSummary": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "position": {
            "type": "string"
          },
          "focus": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "name",
          "position",
          "focus"
        ]
      },
      "AgentAnswer": {
        "type": "object",
        "properties": {
          "answer": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KnowledgeDocument"
            }
          },
          "confidence": {
            "type": "integer",
            "format": "int32"
          },
          "matchedTokens": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "answer",
          "sources",
          "confidence",
          "matchedTokens"
        ]
      },
      "KnowledgeDocument": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "id",
          "title",
          "content",
          "tags"
        ]
      },
      "KnowledgeDocumentRequest": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "content": {
            "type": "string",
            "minLength": 1
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": [
          "id",
          "title",
          "content",
          "tags"
        ]
      }
    }
  }
}
